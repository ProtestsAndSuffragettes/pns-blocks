{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "pns/post-details",
  "title": "PNS Post Details",
  "category": "theme",
  "description": "Automatically displays the current post's date, author, categories, and tags in a news hero.",
  "textdomain": "pns-blocks",
  "usesContext": [
    "postId",
    "postType",
    "queryId"
  ],
  "supports": {
    "anchor": false,
    "customClassName": false,
    "html": false,
    "inserter": false
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}